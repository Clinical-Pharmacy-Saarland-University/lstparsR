$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE MDV EVID DV WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN3 TRANS4
$PK
  CL = THETA(1)  * EXP(ETA(1)) ; CL
  ; V is not used ; V
  ALAG1 = THETA(2)  *(WT)**(THETA(ALAG1~WT)) ; ALAG1
  ; F1
  ; Ka is not used ; Ka
  ALAG2 = THETA(3)  ; ALAG2
  ; F2
  Q = THETA(4)  * EXP(ETA(2)) ; Q
  V1 = THETA(5) *(WT)**(THETA(6)) * EXP(ETA(3))
  SC = V1 ; V1
  V2 = THETA(7) *(WT)**(THETA(8)) * EXP(ETA(4)) ; V2
  ; V3 is not used ; V3
  ; ALAG3 is not used ; ALAG3
  ; F3 is not used ; F3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))
$SIGMA
  ;proportional error
  0.1	; EPS(1)
$THETA
  (0, 1) ; CL 

  ; V is not used
  (0, 1) ; ALAG1
  ; F1 is not used
  ; Ka is not used
  (0, 1) ; ALAG2
  ; F2 is not used
  (0, 1) ; Q 

  (0, 5) ; V1 
  (0.1); V1~WT
  (0, 1) ; V2 
  (0.1); V2~WT
  ; V3 is not used
  ; ALAG3 is not used
  ; F3 is not used
$OMEGA
  0.3  ; CL
  ; V is not used
  ; ALAG1 is not used
  ; F1 is not used
  ; Ka is not used
  ; ALAG2 is not used
  ; F2 is not used
  0.3  ; Q
  0.3  ; V1
  0.3  ; V2
  ; V3 is not used
  ; ALAG3 is not used
  ; F3 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


