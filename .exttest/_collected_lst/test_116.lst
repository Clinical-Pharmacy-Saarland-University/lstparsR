$PROBLEM    Veralipride - 2-compartment oral - double absorption -
;           FOCEI
$INPUT      ID TIME AMT DV
$DATA      data.csv IGNORE=@
$SUBROUTINE ADVAN6 TOL=9
$MODEL      COMP (GUT1) ; first absorption site
            COMP (GUT2) ; second absorption site
            COMP (CENT) ; central compartment
            COMP (PERIPH) ; peripheral compartment
$PK
CL  = THETA(1) * EXP(ETA(1))      ; Clearance (L/h)
V1  = THETA(2) * EXP(ETA(2))      ; Central volume (L)
Q   = THETA(3) * EXP(ETA(3))      ; Intercompartmental clearance (L/h)
V2  = THETA(4) * EXP(ETA(4))      ; Peripheral volume (L)
KA1 = THETA(5) * EXP(ETA(5))      ; Absorption rate 1 (1/h)
KA2 = THETA(6) * EXP(ETA(6))      ; Absorption rate 2 (1/h)
F1  = THETA(7)                    ; fraction of dose to GUT1

K10 = CL / V1
K12 = Q  / V1
K21 = Q  / V2

S3 = V1 / 1000   ; scaling factor to match concentration in mg/L

$THETA  (0,28) ; THETA(1) CL
 (0,230) ; THETA(2) V1
 (0,21) ; THETA(3) Q
 (0,600) ; THETA(4) V2
 (0,1.2) ; THETA(5) KA1
 (0,0.5) ; THETA(6) KA2
 (0,0.5,1) ; THETA(7) F1  (fraction to GUT1)
$OMEGA  0.1  ;  ETA(1) CL
 0.1  ;  ETA(2) V1
 0.1  ;   ETA(3) Q
 0.1  ;  ETA(4) V2
 0.1  ; ETA(5) KA1
 0.1  ; ETA(6) KA2
$SIGMA  0.1  ; residual unexplained variability (proportional)
$DES
; Initial dose is split between GUT1 and GUT2 in $PK
; Here we define the ODEs
DADT(1) = -KA1 * A(1)                                  ; GUT1
DADT(2) = -KA2 * A(2)                                  ; GUT2
DADT(3) =  KA1*A(1) + KA2*A(2) - K10*A(3) - K12*A(3) + K21*A(4)  ; CENT
DADT(4) =               K12*A(3) - K21*A(4)           ; PERIPH

$ERROR
IPRED = A(3) / S3
IRES  = IPRED * EPS(1)
Y = IPRED + IRES

$ESTIMATION METHOD=COND INTER MAXEVAL=9999 PRINT=5
$COVARIANCE
$TABLE      ID TIME IPRED PRED RES WRES CWRES ONEHEADER NOPRINT
            FILE=output.tab

  
