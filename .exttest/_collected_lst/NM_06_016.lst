$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\RemiR/data.csv" IGNORE=@
$SUBROUTINE ADVAN3 TRANS4
$PK

  CL = THETA(1)  *(LBM/50)**(THETA(2))  * EXP(ETA(1)) ; CL

  Q = THETA(3)    * EXP(ETA(2)) ; Q


  TVV1SEX = 0
  IF(SEX == 1) THEN
  TVV1SEX = THETA(4)
  ENDIF
  V1 = THETA(5)  *(LBM/50)**(THETA(6)) *(1 + TVV1SEX) * EXP(ETA(3))
  SC = V1 ; V1


  TVV2SEX = 0
  IF(SEX == 1) THEN
  TVV2SEX = THETA(7)
  ENDIF
  V2 = THETA(8)  *(LBM/50)**(THETA(9)) *(1 + TVV2SEX) ; V2
  ; Q2 is not used ; Q2
  ; Q3 is not used ; Q3
  ; V3 is not used ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA

  (0, 2) ; CL 

  (1); CL~LBM

  (0, 1) ; Q 




  (1);V1~SEX1
  (0, 7) ; V1 

  (1); V1~LBM


  (1);V2~SEX1
  (0, 9) ; V2 

  (1); V2~LBM
  ; Q2 is not used
  ; Q3 is not used
  ; V3 is not used
$OMEGA
  0.03  ; CL
  0.3  ; Q
  0.3  ; V1

  ; Q2 is not used
  ; Q3 is not used
  ; V3 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


