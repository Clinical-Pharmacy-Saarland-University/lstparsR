$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\RemiR/data.csv" IGNORE=@
$SUBROUTINE ADVAN11 TRANS4
$PK

  CL = THETA(1) *(1 + THETA(2) * (AGE))   * EXP(ETA(1)) ; CL
  ; Q is not used ; Q


  TVV1SEX = 0
  IF(SEX == 1) THEN
  TVV1SEX = THETA(3)
  ENDIF
  V1 = THETA(4) *(1 + THETA(5) * (AGE)) *(LBM/50)**(THETA(6)) *(1 + TVV1SEX) * EXP(ETA(2))
  SC = V1 ; V1


  TVV2SEX = 0
  IF(SEX == 1) THEN
  TVV2SEX = THETA(7)
  ENDIF
  V2 = THETA(8) *(1 + THETA(9) * (AGE))  *(1 + TVV2SEX) * EXP(ETA(3)) ; V2


  TVQ2SEX = 0
  IF(SEX == 1) THEN
  TVQ2SEX = THETA(10)
  ENDIF
  Q2 = THETA(11) *(1 + THETA(12) * (AGE))  *(1 + TVQ2SEX) * EXP(ETA(4)) ; Q2

  Q3 = THETA(13) *(1 + THETA(14) * (AGE)) *(LBM/50)**(THETA(15))  * EXP(ETA(5)) ; Q3


  TVV3SEX = 0
  IF(SEX == 1) THEN
  TVV3SEX = THETA(16)
  ENDIF
  V3 = THETA(17) *(1 + THETA(18) * (AGE)) *(LBM/50)**(THETA(19)) *(1 + TVV3SEX) ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA

  (0, 2) ; CL 
  (1); CL~AGE

  ; Q is not used


  (1);V1~SEX1
  (0, 5) ; V1 
  (1); V1~AGE
  (1); V1~LBM


  (1);V2~SEX1
  (0, 10) ; V2 
  (1); V2~AGE



  (0.1);Q2~SEX1
  (0, 2) ; Q2 
  (1); Q2~AGE


  (0, 0.05) ; Q3 
  (1); Q3~AGE
  (1); Q3~LBM


  (1);V3~SEX1
  (0, 5) ; V3 
  (1); V3~AGE
  (1); V3~LBM
$OMEGA
  0.3  ; CL
  ; Q is not used
  0.3  ; V1
  0.3  ; V2
  0.3  ; Q2
  0.3  ; Q3

$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


