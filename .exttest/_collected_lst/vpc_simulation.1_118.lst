28.07.2025 
12:50
$SIZES      PD=-1000 LVR=-150 LTH=-200
$PROBLEM    single pyDarwin individual,one among multitude
$INPUT      ID TIME AMT DV
$DATA      dataset.csv IGNORE=@
$SUBROUTINE ADVAN2 TRANS2
$PK
  CL = THETA(1) * EXP(ETA(1)) ; CL
  Ka = THETA(2) * EXP(ETA(2)) ; Ka
  V = THETA(3) * EXP(ETA(3))
  SC = V/1000 ; V
  ; Q is not used ; Q
  ; V2 is not used ; V2
  ; V3 is not used ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA  0.0556367  ;     EPS(1)
 207.467  ;     EPS(2)
;proportional error
;additive error
$THETA  (0,39.4266) ; CL
 (0,4.43326) ; Ka
 (0,279.977) ; V
; Q is not used
; V2 is not used
; V3 is not used
; Q3 is not used
; Q4 is not used
; V4 is not used
$OMEGA  0.0533117  ;        CL_
 1.10645  ;        Ka_
 0.159234  ;         V_
; Q is not used
; V2 is not used
; V3 is not used
; Q3 is not used
; Q4 is not used
; V4 is not used
$SIMULATION (1413670988) ONLYSIMULATION NSUBPROBLEMS=2000
$TABLE      ID MDV TIME DV ONEHEADER NOPRINT NOAPPEND FILE=npctab.dta

  
