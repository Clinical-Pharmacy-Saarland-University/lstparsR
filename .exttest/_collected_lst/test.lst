$PROBLEM    Veralipride – 2-compartment IV – FOCEI
$INPUT      ID TIME AMT RATE DV
$DATA      data.csv IGNORE=@
$SUBROUTINE ADVAN6 TOL=9
$MODEL      COMP (CENT) ; Central compartment
            COMP (PERIPH) ; Peripheral compartment
$PK
CL = THETA(1) * EXP(ETA(1))       ; Clearance (L/h)
V1 = THETA(2) * EXP(ETA(2))       ; Central volume (L)
Q  = THETA(3) * EXP(ETA(3))       ; Intercompartmental clearance (L/h)
V2 = THETA(4) * EXP(ETA(4))       ; Peripheral volume (L)

K10 = CL / V1
K12 = Q  / V1
K21 = Q  / V2

S1 = V1     ; converts µg → mg/L or similar, adjust as needed

$THETA  (0,2) ; THETA(1) CL
 (0,8) ; THETA(2) V1
 (0,1) ; THETA(3) Q
 (0,8) ; THETA(4) V2
$OMEGA  0.1  ;  ETA(1) CL
 0.1  ;  ETA(2) V1
 0.1  ;   ETA(3) Q
 0.1  ;  ETA(4) V2
$SIGMA  0.1  ; residual unexplained variability (proportional)
$DES
DADT(1) = -K10*A(1) - K12*A(1) + K21*A(2)   ; Central
DADT(2) =  K12*A(1) - K21*A(2)             ; Peripheral

$ERROR
IPRED = A(1) / S1
IRES  = IPRED * EPS(1)
Y = IPRED + IRES

$ESTIMATION METHOD=COND INTER MAXEVAL=9999 PRINT=5
$COVARIANCE
$TABLE      ID TIME IPRED PRED RES WRES CWRES ONEHEADER NOPRINT
            FILE=output.tab

  
