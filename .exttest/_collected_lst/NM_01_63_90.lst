$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT RATE DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN4 ;; advan4 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IOVV = 0  
  TVV2=THETA(1) *CWTKGONE**THETA(6)  *CAGE**THETA(7)   *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IF(OCC.EQ.1) IOVCL = ETA(5) 
  IF(OCC.EQ.2) IOVCL = ETA(6) 
  IF(OCC.EQ.3) IOVCL = ETA(7)
  TVCL= THETA(3) *CWTKGONE**THETA(8)    *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  K23=THETA(4)
  K32=THETA(5)  
  D1=THETA(9) *EXP(ETA(3)) ; infusion only    
  TVKA=THETA(2) 
  KA=TVKA      
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F *EXP(EPS(1))+EPS(2)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,20)	; THETA(3) CL UNITS =  L/HR
  (0.001,0.02)  	 ; THETA(4) K23 
  (0.001,0.3) 	 ; THETA(5) K32 
  ; init for K23~WT    
  (-4,0.8) 	; THETA(6) POWER volume ~WT    

  (-4,0.8) 	; THETA(7) POWER volume ~AGE  

  (-4,.7) 	; THETA(8) POWER clearance~WT  



  (0.01,0.2) 		;; THETA(9) D1  
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  

$OMEGA BLOCK(2) ;; block OMEGA block 
  0.1 		;; ETA(3) ETA ON ALAG1
  0.01 0.1 		;; ETA(4) ETA ON D1   
$OMEGA BLOCK(1) ; ETA(5)
  0.1 
$OMEGA BLOCK SAME ; ETA(6)
$OMEGA BLOCK SAME ; ETA(7)
  ;; no iov ON V
$SIGMA   
  0.1 	; EPS(1) proportional error
  100 	; EPS(2) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

