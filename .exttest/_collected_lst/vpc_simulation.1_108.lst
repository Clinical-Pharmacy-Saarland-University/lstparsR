$SIZES      PD=-1000 LVR=-150 LTH=-200
$PROBLEM    single pyDarwin individual,one among multitude
$INPUT      ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA      data.csv IGNORE=@
$SUBROUTINE ADVAN11 TRANS4
$PK


  TVCLSEX = 0
  IF(SEX == 1) THEN
  TVCLSEX = THETA(1)
  ENDIF
  CL = THETA(2) *(1 + THETA(3) * (AGE)) *(LBM/50)**(THETA(4)) *(1 + TVCLSEX) * EXP(ETA(1)) ; CL
  ; Q is not used ; Q

  V1 = THETA(5)  *(LBM/50)**(THETA(6))  * EXP(ETA(2))
  SC = V1 ; V1

  V2 = THETA(7) *(1 + THETA(8) * (AGE)) *(LBM/50)**(THETA(9))  * EXP(ETA(3)) ; V2

  Q2 = THETA(10)    * EXP(ETA(4)) ; Q2

  Q3 = THETA(11)    * EXP(ETA(5)) ; Q3

  V3 = THETA(12) *(1 + THETA(13) * (AGE))   * EXP(ETA(6)) ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA  0.011717  ;     EPS(1)
 0.00030316  ;     EPS(2)
;proportional error
;additive error
$THETA  -0.0666447 ; CL~SEX1
 (0,3.2021) ; CL
 -0.00478794 ; CL~AGE
 0.558575 ; CL~LBM
 (0,3.91548) ; V1
 1.44432 ; V1~LBM
 (0,12.2974) ; V2
 -0.00726353 ; V2~AGE
 0.541183 ; V2~LBM
 (0,1.88076) ; Q2
 (0,0.133808) ; Q3
 (0,5.0233) ; V3
 -0.00846505 ; V3~AGE
; Q is not used
$OMEGA  0.0196573  ;        CL_
 0.0697635  ;        V1_
 0.104366  ;        V2_
 0.340503  ;        Q2_
 0.264263  ;        Q3_
 0.264548  ;        V3_
; Q is not used
$SIMULATION (1222279914) ONLYSIMULATION NSUBPROBLEMS=2000
$TABLE      ID MDV SEX TIME DV ONEHEADER NOPRINT NOAPPEND
            FILE=npctab.dta

  
