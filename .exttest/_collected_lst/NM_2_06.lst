$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE MDV EVID DV WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
  CL = THETA(1) *(WT)**(THETA(2)) * EXP(ETA(1)) ; CL
  ; V is not used ; V
  ALAG1 = THETA(3)   ; ALAG1
  F1 = THETA(4)   * EXP(ETA(2)) ; F1
  Ka = THETA(5)  * EXP(ETA(3)) ; Ka
  ALAG2 = THETA(6)  * EXP(ETA(4)) ; ALAG2
  ; F2
  Q = THETA(7) *(WT)**(THETA(8)) * EXP(ETA(5)) ; Q
  ; V1 is not used ; V1
  V2 = THETA(9) *(WT)**(THETA(10)) * EXP(ETA(6))
  SC = V2 ; V2
  V3 = THETA(11) *(WT)**(THETA(12)) * EXP(ETA(7)) ; V3
  ; ALAG3
  F3 = THETA(13)  * EXP(ETA(8)) ; F3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))
$SIGMA
  ;proportional error
  0.1	; EPS(1)
$THETA
  (0, 1) ; CL 
  (0.1); CL~WT
  ; V is not used
  (0, 1) ; ALAG1
  (0, 0.5) ; F1
  (0, 1) ; Ka 

  (0, 1) ; ALAG2
  ; F2 is not used
  (0, 1) ; Q 
  (0.1); Q~WT
  ; V1 is not used
  (0, 5) ; V2 
  (0.1); V2~WT
  (0, 1) ; V3 
  (0.1); V3~WT
  ; ALAG3 is not used
  (0, 0.5) ; F3
$OMEGA
  0.3  ; CL
  ; V is not used
  ; ALAG1 is not used
  0.3  ; F1
  0.3  ; Ka
  0.3  ; ALAG2
  ; F2 is not used
  0.3  ; Q
  ; V1 is not used
  0.3  ; V2
  0.3  ; V3
  ; ALAG3 is not used
  0.3  ; F3
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


;; Phenotype: ({'ADVAN': 3, 'CL~WT': 1, 'CL_OMEGA': 0, 'V~WT': 1, 'V_OMEGA': 1, 'ALAG1_OMEGA': 0, 'ALAG1~WT': 0, 'ALAG1_THETA': 1, 'F1_OMEGA': 1, 'F1~WT': 0, 'F1_THETA': 1, 'Ka~WT': 0, 'Ka_OMEGA': 0, 'ALAG2_OMEGA': 1, 'ALAG2_THETA': 1, 'F2_OMEGA': 1, 'F2_THETA': 0, 'Q~WT': 1, 'V1~WT': 1, 'V2~WT': 1, 'V3~WT': 1, 'ALAG3_OMEGA': 1, 'ALAG3_THETA': 0, 'F3_OMEGA': 1, 'F3_THETA': 1, 'RESERR': 0})
