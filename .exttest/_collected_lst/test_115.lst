$PROBLEM Veralipride - 2-compartment oral - FOCEI

$INPUT ID TIME AMT DV

$DATA data.csv IGNORE=@
$SUBROUTINE ADVAN6 TOL=9

$MODEL
COMP (GUT)    ; depot compartment
COMP (CENT)   ; central compartment
COMP (PERIPH) ; peripheral compartment

$PK
CL = THETA(1) * EXP(ETA(1))      ; Clearance (L/h)
V1 = THETA(2) * EXP(ETA(2))      ; Central volume (L)
Q  = THETA(3) * EXP(ETA(3))      ; Intercompartmental clearance (L/h)
V2 = THETA(4) * EXP(ETA(4))      ; Peripheral volume (L)
KA = THETA(5) * EXP(ETA(5))      ; Absorption rate constant (1/h)

K10 = CL / V1
K12 = Q  / V1
K21 = Q  / V2

S2 = V1 / 1000   ; scaling factor to match concentration in mg/L

$THETA
(0, 28)       ; THETA(1) CL
(0, 230)      ; THETA(2) V1
(0, 21)       ; THETA(3) Q
(0, 600)      ; THETA(4) V2
(0, 1.2)      ; THETA(5) KA

$OMEGA
0.1 ; ETA(1) CL
0.1 ; ETA(2) V1
0.1 ; ETA(3) Q
0.1 ; ETA(4) V2
0.1 ; ETA(5) KA

$SIGMA
0.1 ; residual unexplained variability (proportional)

$DES
DADT(1) = -KA * A(1)                                     ; GUT
DADT(2) =  KA * A(1) - K10*A(2) - K12*A(2) + K21*A(3)    ; CENT
DADT(3) =               K12*A(2) - K21*A(3)             ; PERIPH

$ERROR
IPRED = A(2) / S2
IRES  = IPRED * EPS(1)
Y = IPRED + IRES

$ESTIMATION METHOD=COND INTER MAXEVAL=9999 PRINT=5
$COVARIANCE

$TABLE ID TIME IPRED PRED RES WRES CWRES ONEHEADER NOPRINT FILE=output.tab
  
