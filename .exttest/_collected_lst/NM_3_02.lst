$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE MDV EVID DV WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN2 TRANS2
$PK
  CL = THETA(1)  * EXP(ETA(1)) ; CL
  V = THETA(2)  * EXP(ETA(2))
  SC = V ; V
  ; ALAG1
  F1 = THETA(3)  *(WT)**(THETA(F1~WT)) * EXP(ETA(3)) ; F1
  Ka = THETA(4)  * EXP(ETA(4)) ; Ka
  ; ALAG2
  ; F2
  ; Q is not used ; Q
  ; V1 is not used ; V1
  ; V2 is not used ; V2
  ; V3 is not used ; V3
  ; ALAG3 is not used ; ALAG3
  ; F3 is not used ; F3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA
  (0, 1) ; CL 

  (0, 5) ; V 

  ; ALAG1 is not used
  (0, 0.5) ; F1
  (0, 1) ; Ka 

  ; ALAG2 is not used
  ; F2 is not used
  ; Q is not used
  ; V1 is not used
  ; V2 is not used
  ; V3 is not used
  ; ALAG3 is not used
  ; F3 is not used
$OMEGA
  0.3  ; CL
  0.3  ; V
  ; ALAG1 is not used
  0.3  ; F1
  0.3  ; Ka
  ; ALAG2 is not used
  ; F2 is not used
  ; Q is not used
  ; V1 is not used
  ; V2 is not used
  ; V3 is not used
  ; ALAG3 is not used
  ; F3 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


