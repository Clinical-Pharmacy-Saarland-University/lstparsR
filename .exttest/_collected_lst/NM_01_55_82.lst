$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT RATE DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN12 ;; advan12 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IOVV = 0  
  TVV2=THETA(1)    *EXP(COV2*THETA(9))  *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IOVCL = 0
  TVCL= THETA(3)  *CAGE**THETA(10)  *EXP(CCOV1*THETA(11)) *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  K23=THETA(4)*CWTKGONE**THETA(8)
  K32=THETA(5)*CWTKGONE**THETA(8)
  K24=THETA(6)
  K42=THETA(7)  
  ALAG1=THETA(12)*EXP(ETA(3))
  D1=THETA(13)*EXP(ETA(4))    
  TVKA=THETA(2) 
  KA=TVKA      
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F +EPS(1)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,2)	; THETA(3) CL UNITS =  L/HR
  (0.001,0.1) 	; THETA(4) K23 
  (0.001,0.1)	; THETA(5) K32 
  (0.001,0.1) 	; THETA(6) K24  
  (0.001,0.1) 	; THETA(7) K42  
  (0,0.1) 	; THETA(8) K23~WT 	 ;; init for K23~WT   



  (-4,0.1) 	; THETA(9) EXPONENTIAL volume ~COV2 

  (-4,.7) 	; THETA(10) POWER clearance~AGE  

  (-4,0.1) 	; THETA(11) EXPONENTIAL CL~COV1 
  (0.001,0.1,1) 		;; THETA(12) ALAG1
  (0.001,0.1,1) ;;THETA(13) D1
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  

$OMEGA BLOCK(2) ;; block OMEGA block 
  0.1 		;; ETA(3) ETA ON ALAG1
  0.01 0.1 		;; ETA(4) ETA ON D1 		;; D1 and lag, block 
  ;; no iov ON CL
  ;; no iov ON V
$SIGMA   
  200 	; EPS(1) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 2, 'K23~WT': 1, 'KAETA': 0, 'V2~WT': 0, 'V2~AGE': 0, 'V2~SEX': 0, 'V2~COV2': 1, 'CL~WT': 0, 'CL~AGE': 1, 'CL~CRCL': 0, 'CL~COV1': 1, 'IOVCL': 1, 'IOVV': 1, 'INITCL': 0, 'ETAD1LAG': 4, 'D1LAG': 2, 'RESERR': 1})
