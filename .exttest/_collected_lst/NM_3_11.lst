$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE MDV EVID DV WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
  CL = THETA(1)  * EXP(ETA(1)) ; CL
  ; V is not used ; V
  ; ALAG1
  F1 = THETA(2)   * EXP(ETA(2)) ; F1
  Ka = THETA(3)  * EXP(ETA(3)) ; Ka
  ALAG2 = THETA(4)  * EXP(ETA(4)) ; ALAG2
  ; F2
  Q = THETA(5)  * EXP(ETA(5)) ; Q
  ; V1 is not used ; V1
  V2 = THETA(6) *(WT)**(THETA(7)) * EXP(ETA(6))
  SC = V2 ; V2
  V3 = THETA(8)  * EXP(ETA(7)) ; V3
  ALAG3 = THETA(9)  ; ALAG3
  F3 = THETA(10)  * EXP(ETA(8)) ; F3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA
  (0, 1) ; CL 

  ; V is not used
  ; ALAG1 is not used
  (0, 0.5) ; F1
  (0, 1) ; Ka 

  (0, 1) ; ALAG2
  ; F2 is not used
  (0, 1) ; Q 

  ; V1 is not used
  (0, 5) ; V2 
  (0.1); V2~WT
  (0, 1) ; V3 

  (0, 1) ; ALAG3
  (0, 0.5) ; F3
$OMEGA
  0.3  ; CL
  ; V is not used
  ; ALAG1 is not used
  0.3  ; F1
  0.3  ; Ka
  0.3  ; ALAG2
  ; F2 is not used
  0.3  ; Q
  ; V1 is not used
  0.3  ; V2
  0.3  ; V3
  ; ALAG3 is not used
  0.3  ; F3
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


