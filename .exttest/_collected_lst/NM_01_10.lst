$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT RATE DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN2 ;; advan2 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IOVV = 0  
  TVV2=THETA(1)  *EXP(SEX*THETA(4))  *EXP(COV2*THETA(5))  *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IF(OCC.EQ.1) IOVCL = ETA(6) 
  IF(OCC.EQ.2) IOVCL = ETA(7) 
  IF(OCC.EQ.3) IOVCL = ETA(8)
  TVCL= THETA(3)  *CAGE**THETA(6) *CCRCL**THETA(7) *EXP(CCOV1*THETA(8)) *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  ;; PK 1 compartment   
  D1=THETA(9) *EXP(ETA(4)) ; infusion only    
  TVKA=THETA(2) 
  KA=TVKA  *EXP(ETA(3))     
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F +EPS(1)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,2)	; THETA(3) CL UNITS =  L/HR
  ;; THETA 1 compartment   

  (-4,0.1) 	; THETA(4) EXPONENTIAL volume~SEX    

  (-4,0.1) 	; THETA(5) EXPONENTIAL volume ~COV2 

  (-4,.7) 	; THETA(6) POWER clearance~AGE  
  (-4,-0.2) 	; THETA(7) POWER clearance~CRCL 
  (-4,0.1) 	; THETA(8) EXPONENTIAL CL~COV1 
  (0.01,0.2) 		;; THETA(9) D1  
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  
$OMEGA ;; 2nd OMEGA block 
  0.1		; ETA(3) ETA ON KA  
$OMEGA  ;; diagonal OMEGA 
  0.1 		;; ETA(4) ETA ON ALAG1
  0.1 		;; ETA(5) ETA ON D1   
$OMEGA BLOCK(1) ; ETA(6)
  0.1 
$OMEGA BLOCK SAME ; ETA(7)
$OMEGA BLOCK SAME ; ETA(8)
  ;; no iov ON V
$SIGMA   
  200 	; EPS(1) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 0, 'K23~WT': 1, 'KAETA': 1, 'V2~WT': 0, 'V2~AGE': 0, 'V2~SEX': 1, 'V2~COV2': 1, 'CL~WT': 0, 'CL~AGE': 1, 'CL~CRCL': 1, 'CL~COV1': 1, 'IOVCL': 0, 'IOVV': 1, 'INITCL': 0, 'ETAD1LAG': 3, 'D1LAG': 1, 'RESERR': 1})
