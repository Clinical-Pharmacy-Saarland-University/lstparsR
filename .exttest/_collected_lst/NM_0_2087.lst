$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT DV WT EVID MDV
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\Datasets\Theo/dataset.csv" IGNORE=@
$SUBROUTINE ADVAN12 TRANS4
$PK
  CL = THETA(1)*(WT/70)**(1) * EXP(ETA(1)) ; CL
  Ka = THETA(2) * EXP(ETA(2)) ; Ka
  ; V is not used ; V
  ; Q is not used ; Q
  V2 = THETA(3)*(WT/70)**(1) * EXP(ETA(3))
  SC = V2 ; V2
  V3 = THETA(4) * EXP(ETA(4)) ; V3
  Q3 = THETA(5) * EXP(ETA(5)) ; Q3
  Q4 = THETA(6) ; Q4
  V4 = THETA(7) ; V4
$ERROR
  IPRED = F
  Y = F +EPS(1)
$SIGMA
  ;additive error only
  1	; EPS(1)
$THETA
  (0, 5) ; CL 
  (0, 1) ; Ka 
  ; V is not used
  ; Q is not used
  (0, 50) ; V2 
  (0, 80) ; V3 
  (0, 6) ; Q3 
  (0, 1) ; Q4 
  (0, 200) ; V4 
$OMEGA
  0.3  ; CL
  0.3  ; Ka
  ; V is not used
  ; Q is not used
  0.3  ; V2
  0.3  ; V3
  0.3  ; Q3
  ; Q4 is not used
  ; V4 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


