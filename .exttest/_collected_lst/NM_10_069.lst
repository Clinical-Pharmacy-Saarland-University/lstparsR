$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\RemiR/data.csv" IGNORE=@
$SUBROUTINE ADVAN11 TRANS4
$PK

  CL = THETA(1)  *(LBM/50)**(THETA(2))  * EXP(ETA(1)) ; CL
  ; Q is not used ; Q


  TVV1SEX = 0
  IF(SEX == 1) THEN
  TVV1SEX = THETA(3)
  ENDIF
  V1 = THETA(4)  *(LBM/50)**(THETA(5)) *(1 + TVV1SEX) * EXP(ETA(2))
  SC = V1 ; V1

  V2 = THETA(6) *(1 + THETA(7) * (AGE))   * EXP(ETA(3)) ; V2

  Q2 = THETA(8) *(1 + THETA(9) * (AGE))   * EXP(ETA(4)) ; Q2


  TVQ3SEX = 0
  IF(SEX == 1) THEN
  TVQ3SEX = THETA(10)
  ENDIF
  Q3 = THETA(11) *(1 + THETA(12) * (AGE)) *(LBM/50)**(THETA(13)) *(1 + TVQ3SEX) * EXP(ETA(5)) ; Q3

  V3 = THETA(14)    ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))
$SIGMA
  ;proportional error
  0.1	; EPS(1)
$THETA

  (0, 2) ; CL 

  (1); CL~LBM
  ; Q is not used


  (1);V1~SEX1
  (0, 5) ; V1 

  (1); V1~LBM

  (0, 10) ; V2 
  (1); V2~AGE


  (0, 2) ; Q2 
  (1); Q2~AGE



  (1);Q3~SEX1
  (0, 0.05) ; Q3 
  (1); Q3~AGE
  (1); Q3~LBM

  (0, 5) ; V3 


$OMEGA
  0.3  ; CL
  ; Q is not used
  0.3  ; V1
  0.3  ; V2
  0.3  ; Q2
  0.3  ; Q3

$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


