$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT DV WT EVID MDV
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\Datasets\Theo/dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
  CL = THETA(1)*(WT/70)**(1) ; CL
  Ka = THETA(2) ; Ka
  ; V is not used ; V
  Q = THETA(3) ; Q
  V2 = THETA(4)
  SC = V2 ; V2
  V3 = THETA(5) ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA
  (0, 5) ; CL 
  (0, 1) ; Ka 
  ; V is not used
  (0, 6) ; Q 
  (0, 50) ; V2 
  (0, 100) ; V3 
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
; empty $OMEGA


  ; V is not used



  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


