$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\RemiR/data.csv" IGNORE=@
$SUBROUTINE ADVAN11 TRANS4
$PK


  TVCLSEX = 0
  IF(SEX == 1) THEN
  TVCLSEX = THETA(1)
  ENDIF
  CL = THETA(2)   *(1 + TVCLSEX) * EXP(ETA(1)) ; CL
  ; Q is not used ; Q

  V1 = THETA(3)  *(LBM/50)**(THETA(4))  * EXP(ETA(2))
  SC = V1 ; V1

  V2 = THETA(5) *(1 + THETA(6) * (AGE))   * EXP(ETA(3)) ; V2


  TVQ2SEX = 0
  IF(SEX == 1) THEN
  TVQ2SEX = THETA(7)
  ENDIF
  Q2 = THETA(8) *(1 + THETA(9) * (AGE))  *(1 + TVQ2SEX) * EXP(ETA(4)) ; Q2


  TVQ3SEX = 0
  IF(SEX == 1) THEN
  TVQ3SEX = THETA(10)
  ENDIF
  Q3 = THETA(11) *(1 + THETA(12) * (AGE))  *(1 + TVQ3SEX) * EXP(ETA(5)) ; Q3


  TVV3SEX = 0
  IF(SEX == 1) THEN
  TVV3SEX = THETA(13)
  ENDIF
  V3 = THETA(14)   *(1 + TVV3SEX) ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA


  (1.1);CL~SEX1
  (0, 2) ; CL 


  ; Q is not used

  (0, 5) ; V1 

  (1); V1~LBM

  (0, 10) ; V2 
  (1); V2~AGE



  (0.1);Q2~SEX1
  (0, 2) ; Q2 
  (1); Q2~AGE



  (1);Q3~SEX1
  (0, 0.05) ; Q3 
  (1); Q3~AGE



  (1);V3~SEX1
  (0, 5) ; V3 


$OMEGA
  0.3  ; CL
  ; Q is not used
  0.3  ; V1
  0.3  ; V2
  0.3  ; Q2
  0.3  ; Q3

$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


