$SIZES      PD=-1000 LVR=-150 LTH=-200
$PROBLEM    single pyDarwin individual,one among multitude
$INPUT      ID TIME AMT DV WT EVID MDV
$DATA      dataset.csv IGNORE=@
$SUBROUTINE ADVAN2 TRANS2
$PK
  CL = THETA(1) * EXP(ETA(1)) ; CL
  Ka = THETA(2) * EXP(ETA(2)) ; Ka
  V = THETA(3)
  SC = V ; V
  ; Q is not used ; Q
  ; V2 is not used ; V2
  ; V3 is not used ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA  0.0230744  ;     EPS(1)
 0.072738  ;     EPS(2)
;proportional error
;additive error
$THETA  (0,2.7832) ; CL
 (0,1.42381) ; Ka
 (0,31.4946) ; V
; Q is not used
; V2 is not used
; V3 is not used
; Q3 is not used
; Q4 is not used
; V4 is not used
$OMEGA  0.0705156  ;        CL_
 0.336801  ;        Ka_
; Q is not used
; V2 is not used
; V3 is not used
; Q3 is not used
; Q4 is not used
; V4 is not used
$SIMULATION (1734139963) ONLYSIMULATION NSUBPROBLEMS=2000
$TABLE      ID MDV TIME DV ONEHEADER NOPRINT NOAPPEND FILE=npctab.dta

  
