$SIZES      PD=-1000 LVR=-150 LTH=-200
$PROBLEM    single pyDarwin individual,one among multitude
$INPUT      ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA      data.csv IGNORE=@
$SUBROUTINE ADVAN11 TRANS4
$PK

  CL = THETA(1) *(1 + THETA(2) * (AGE)) *(LBM/50)**(THETA(3))  * EXP(ETA(1)) ; CL
  ; Q is not used ; Q

  V1 = THETA(4)  *(LBM/50)**(THETA(5))  * EXP(ETA(2))
  SC = V1 ; V1

  V2 = THETA(6)  *(LBM/50)**(THETA(7))  * EXP(ETA(3)) ; V2

  Q2 = THETA(8)    * EXP(ETA(4)) ; Q2


  TVQ3SEX = 0
  IF(SEX == 1) THEN
  TVQ3SEX = THETA(9)
  ENDIF
  Q3 = THETA(10)   *(1 + TVQ3SEX) * EXP(ETA(5)) ; Q3

  V3 = THETA(11)    * EXP(ETA(6)) ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA  0.0118  ;     EPS(1)
 0.000226  ;     EPS(2)
;proportional error
;additive error
$THETA  3.08 ; THETA(1)  - CL base
 -0.00467 ; THETA(2)  - CL ~ AGE
 0.427 ; THETA(3)  - CL ~ LBM
 4.04 ; THETA(4)  - V1 base
 1.32 ; THETA(5)  - V1 ~ LBM
 8.06 ; THETA(6)  - V2 base
 0.631 ; THETA(7)  - V2 ~ LBM
 1.87 ; THETA(8)  - Q2
 1.56 ; THETA(9)  - Q3 ~ SEX
 0.0592 ; THETA(10) - Q3 base
 3.42 ; THETA(11) - V3
; Final parameter estimates
$OMEGA  0.0204  ;         CL
 0.0716  ;         V1
 0.154  ;         V2
 0.318  ;         Q2
 0.405  ;         Q3
 0.428  ;         V3
; Q is not used
$SIMULATION (355241442) ONLYSIMULATION NSUBPROBLEMS=2000
$TABLE      ID MDV SEX TIME DV ONEHEADER NOPRINT NOAPPEND
            FILE=npctab.dta

  
NM-TRAN MESSAGES 
  
