$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT DROP DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN2 ;; advan2 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IOVV = 0  
  TVV2=THETA(1)    *EXP(COV2*THETA(4))  *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IF(OCC.EQ.1) IOVCL = ETA(3) 
  IF(OCC.EQ.2) IOVCL = ETA(4) 
  IF(OCC.EQ.3) IOVCL = ETA(5)
  TVCL= THETA(3)     *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  ;; PK 1 compartment   
  ALAG1=THETA(5)
  ;; No D1    
  TVKA=THETA(2) 
  KA=TVKA      
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F *EXP(EPS(1))+EPS(2)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,2)	; THETA(3) CL UNITS =  L/HR
  ;; THETA 1 compartment   



  (-4,0.1) 	; THETA(4) EXPONENTIAL volume ~COV2 




  (0.001,0.1) 	; THETA(5) ALAG1   
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  


$OMEGA BLOCK(1) ; ETA(3)
  0.1 
$OMEGA BLOCK SAME ; ETA(4)
$OMEGA BLOCK SAME ; ETA(5)
  ;; no iov ON V
$SIGMA   
  0.1 	; EPS(1) proportional error
  100 	; EPS(2) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 0, 'K23~WT': 0, 'KAETA': 0, 'V2~WT': 0, 'V2~AGE': 0, 'V2~SEX': 0, 'V2~COV2': 1, 'CL~WT': 0, 'CL~AGE': 0, 'CL~CRCL': 0, 'CL~COV1': 0, 'IOVCL': 0, 'IOVV': 1, 'INITCL': 0, 'ETAD1LAG': 0, 'D1LAG': 0, 'RESERR': 0})
