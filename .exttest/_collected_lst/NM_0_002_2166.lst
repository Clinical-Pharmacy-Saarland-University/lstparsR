$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME DV AMT EVID MDV CMT WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN2 TRANS2
$PK
  CL = THETA(1) *(WT/70)**(THETA(2)) ; CL
  Ka = THETA(3) ; Ka
  V = THETA(4) 
  SC = V ; V
  ; Q is not used ; Q
  ; V2 is not used ; V2
  ; V3 is not used ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))
$SIGMA
  ;proportional error
  0.015	; EPS(1)
$THETA
  (0, 2) ; CL 
  (0.5); CL~WT
  (0, 1) ; Ka
  (0, 25) ; V 

  ; Q is not used
  ; V2 is not used
  ; V3 is not used
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
; empty $OMEGA

  ; Ka is not used

  ; Q is not used
  ; V2 is not used
  ; V3 is not used
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


