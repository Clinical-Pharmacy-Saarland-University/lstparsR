$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\RemiR/data.csv" IGNORE=@
$SUBROUTINE ADVAN11 TRANS4
$PK

  CL = THETA(1) *(1 + THETA(2) * (AGE)) *(LBM/50)**(THETA(3))  * EXP(ETA(1)) ; CL
  ; Q is not used ; Q

  V1 = THETA(4)  *(LBM/50)**(THETA(5))  * EXP(ETA(2))
  SC = V1 ; V1

  V2 = THETA(6)    * EXP(ETA(3)) ; V2

  Q2 = THETA(7) *(1 + THETA(8) * (AGE))   * EXP(ETA(4)) ; Q2

  Q3 = THETA(9) *(1 + THETA(10) * (AGE))   * EXP(ETA(5)) ; Q3


  TVV3SEX = 0
  IF(SEX == 1) THEN
  TVV3SEX = THETA(11)
  ENDIF
  V3 = THETA(12) *(1 + THETA(13) * (AGE))  *(1 + TVV3SEX) * EXP(ETA(6)) ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA

  (0, 2) ; CL 
  (1); CL~AGE
  (1); CL~LBM
  ; Q is not used

  (0, 5) ; V1 

  (1); V1~LBM

  (0, 10) ; V2 



  (0, 2) ; Q2 
  (1); Q2~AGE


  (0, 0.05) ; Q3 
  (1); Q3~AGE



  (1);V3~SEX1
  (0, 5) ; V3 
  (1); V3~AGE

$OMEGA
  0.3  ; CL
  ; Q is not used
  0.3  ; V1
  0.3  ; V2
  0.3  ; Q2
  0.3  ; Q3
  0.3  ; V3
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


