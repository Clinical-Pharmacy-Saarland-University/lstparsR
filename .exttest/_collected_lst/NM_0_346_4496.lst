$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME DV AMT EVID MDV CMT WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
  CL = THETA(1) *(WT/70)**(THETA(2)) * EXP(ETA(1)) ; CL
  Ka = THETA(3) ; Ka
  ; V is not used ; V
  Q = THETA(4) ; Q
  V2 = THETA(5) *(WT/70)**(THETA(6)) * EXP(ETA(2))
  SC = V2 ; V2
  V3 = THETA(7)  * EXP(ETA(3)) ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))
$SIGMA
  ;proportional error
  0.015	; EPS(1)
$THETA
  (0, 2) ; CL 
  (0.5); CL~WT
  (0, 1) ; Ka
  ; V is not used
  (0, 25) ; Q
  (0, 5) ; V2 
  (0.5); V2~WT
  (0, 1) ; V3
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$OMEGA
  0.1  ; CL
  ; Ka is not used
  ; V is not used
  ; Q is not used
  0.1  ; V2
  0.1  ; V3
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


;; Phenotype: ([('ADVAN', 1), ('CL~WT', 1), ('CL_OMEGA', 1), ('V2~WT', 1), ('V2_OMEGA', 1), ('V3_OMEGA', 1), ('RESERR', 0)])
