$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT DROP DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN12 ;; advan12 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IF(OCC.EQ.1) IOVV = ETA(6) 
  IF(OCC.EQ.2) IOVV = ETA(7) 
  IF(OCC.EQ.3) IOVV = ETA(8)  
  TVV2=THETA(1) *CWTKGONE**THETA(8) *EXP(SEX*THETA(9)) *CAGE**THETA(10) *EXP(COV2*THETA(11))  *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IOVCL = 0
  TVCL= THETA(3) *EXP(CWTKGZERO*THETA(12)) *CAGE**THETA(13) *CCRCL**THETA(14)  *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  K23=THETA(4)
  K32=THETA(5)
  K24=THETA(6)
  K42=THETA(7)  
  ALAG1=THETA(15)*EXP(ETA(4))
  ;; No D1    
  TVKA=THETA(2) 
  KA=TVKA  *EXP(ETA(3))     
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F +EPS(1)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,20)	; THETA(3) CL UNITS =  L/HR
  (0.001,0.1) 	; THETA(4) K23 
  (0.001,0.1)	; THETA(5) K32 
  (0.001,0.1) 	; THETA(6) K24  
  (0.001,0.1) 	; THETA(7) K42  
  ;; init for K23~WT   
  (-4,0.8) 	; THETA(8) POWER volume ~WT    
  (-4,0.1) 	; THETA(9) EXPONENTIAL volume~SEX    
  (-4,0.8) 	; THETA(10) POWER volume ~AGE  
  (-4,0.1) 	; THETA(11) EXPONENTIAL volume ~COV2 
  (-1,0.01) 	; THETA(12) EXPONENTIAL clearance~WT  
  (-4,.7) 	; THETA(13) POWER clearance~AGE  
  (-4,-0.2) 	; THETA(14) POWER clearance~CRCL 

  (0.001,0.1) 	; THETA(15) ALAG1   
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  
$OMEGA ;; 2nd OMEGA block 
  0.1		; ETA(3) ETA ON KA  
$OMEGA BLOCK(2) ;; block OMEGA block 
  0.1 		;; ETA(4) ETA ON ALAG1
  0.01 0.1 		;; ETA(5) ETA ON D1 
  ;; no iov ON CL
$OMEGA BLOCK(1) ; ETA(6)
  0.1 
$OMEGA BLOCK SAME ; ETA(7)
$OMEGA BLOCK SAME ; ETA(8)
$SIGMA   
  200 	; EPS(1) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 2, 'K23~WT': 0, 'KAETA': 1, 'V2~WT': 1, 'V2~AGE': 1, 'V2~SEX': 1, 'V2~COV2': 1, 'CL~WT': 2, 'CL~AGE': 1, 'CL~CRCL': 1, 'CL~COV1': 0, 'IOVCL': 1, 'IOVV': 0, 'INITCL': 1, 'ETAD1LAG': 4, 'D1LAG': 0, 'RESERR': 1})
;; Genotype: [2, 0, 1, 1, 1, 1, 1, 2, 1, 1, 0, 1, 0, 1, 4, 0, 1]
;; Num non-influential tokens: 0
  
