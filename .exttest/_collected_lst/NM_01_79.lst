$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT RATE DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN4 ;; advan4 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IF(OCC.EQ.1) IOVV = ETA(4) 
  IF(OCC.EQ.2) IOVV = ETA(5) 
  IF(OCC.EQ.3) IOVV = ETA(6)  
  TVV2=THETA(1) *EXP(CWTKGZERO*THETA(7)) *EXP(SEX*THETA(8))  *EXP(COV2*THETA(9))  *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IOVCL = 0
  TVCL= THETA(3) *EXP(CWTKGZERO*THETA(10))    *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  K23=THETA(4)*CWTKGONE**THETA(6)
  K32=THETA(5)*CWTKGONE**THETA(6)  
  ALAG1=THETA(11)
  D1=THETA(12)*EXP(ETA(3))    
  TVKA=THETA(2) 
  KA=TVKA      
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F *EXP(EPS(1))+EPS(2)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,20)	; THETA(3) CL UNITS =  L/HR
  (0.001,0.02)  	 ; THETA(4) K23 
  (0.001,0.3) 	 ; THETA(5) K32 
  (0,0.1) 	; THETA(6) K23~WT 	 ; init for K23~WT    
  (-1,0.01) 	; THETA(7) EXPONENTIAL volume ~WT    
  (-4,0.1) 	; THETA(8) EXPONENTIAL volume~SEX    

  (-4,0.1) 	; THETA(9) EXPONENTIAL volume ~COV2 
  (-1,0.01) 	; THETA(10) EXPONENTIAL clearance~WT  



  (0.001,0.1,1) 		;; THETA(11) ALAG1
  (0.001,0.1,1) ;;THETA(12) D1
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  

$OMEGA ;;  
  0.1 		;; ETA(3) ETA ON D1 		;; D1 and lag, block 
  ;; no iov ON CL
$OMEGA BLOCK(1) ; ETA(4)
  0.1 
$OMEGA BLOCK SAME ; ETA(5)
$OMEGA BLOCK SAME ; ETA(6)
$SIGMA   
  0.1 	; EPS(1) proportional error
  100 	; EPS(2) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 1, 'K23~WT': 1, 'KAETA': 0, 'V2~WT': 2, 'V2~AGE': 0, 'V2~SEX': 1, 'V2~COV2': 1, 'CL~WT': 2, 'CL~AGE': 0, 'CL~CRCL': 0, 'CL~COV1': 0, 'IOVCL': 1, 'IOVV': 0, 'INITCL': 1, 'ETAD1LAG': 2, 'D1LAG': 2, 'RESERR': 0})
