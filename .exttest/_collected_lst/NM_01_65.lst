$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT RATE DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN2 ;; advan2 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IOVV = 0  
  TVV2=THETA(1)   *CAGE**THETA(4)   *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IOVCL = 0
  TVCL= THETA(3) *EXP(CWTKGZERO*THETA(5))  *CCRCL**THETA(6)  *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  ;; PK 1 compartment   
  ALAG1=THETA(7)*EXP(ETA(4))
  D1=THETA(8)    
  TVKA=THETA(2) 
  KA=TVKA  *EXP(ETA(3))     
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F *EXP(EPS(1))+EPS(2)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,2)	; THETA(3) CL UNITS =  L/HR
  ;; THETA 1 compartment   


  (-4,0.8) 	; THETA(4) POWER volume ~AGE  

  (-1,0.01) 	; THETA(5) EXPONENTIAL clearance~WT  

  (-4,-0.2) 	; THETA(6) POWER clearance~CRCL 

  (0.001,0.1,1) 		;; THETA(7) ALAG1
  (0.001,0.1,1) ;;THETA(8) D1
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  
$OMEGA ;; 2nd OMEGA block 
  0.1		; ETA(3) ETA ON KA  
$OMEGA ;; 3rd OMEGA block 
  0.1 		;; ETA(4) ETA ON ALAG1 		;; D1 and lag, block 
  ;; no iov ON CL
  ;; no iov ON V
$SIGMA   
  0.1 	; EPS(1) proportional error
  100 	; EPS(2) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 0, 'K23~WT': 0, 'KAETA': 1, 'V2~WT': 0, 'V2~AGE': 1, 'V2~SEX': 0, 'V2~COV2': 0, 'CL~WT': 2, 'CL~AGE': 0, 'CL~CRCL': 1, 'CL~COV1': 0, 'IOVCL': 1, 'IOVV': 1, 'INITCL': 0, 'ETAD1LAG': 1, 'D1LAG': 2, 'RESERR': 0})
