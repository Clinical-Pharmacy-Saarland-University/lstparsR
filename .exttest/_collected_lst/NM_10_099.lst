$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\RemiR/data.csv" IGNORE=@
$SUBROUTINE ADVAN3 TRANS4
$PK


  TVCLSEX = 0
  IF(SEX == 1) THEN
  TVCLSEX = THETA(1)
  ENDIF
  CL = THETA(2)   *(1 + TVCLSEX) ; CL

  Q = THETA(3) *(1 + THETA(4) * (AGE))   ; Q

  V1 = THETA(5) *(1 + THETA(6) * (AGE))  
  SC = V1 ; V1


  TVV2SEX = 0
  IF(SEX == 1) THEN
  TVV2SEX = THETA(7)
  ENDIF
  V2 = THETA(8)   *(1 + TVV2SEX) ; V2
  ; Q2 is not used ; Q2
  ; Q3 is not used ; Q3
  ; V3 is not used ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA


  (1.1);CL~SEX1
  (0, 2) ; CL 



  (0, 1) ; Q 
  (1); Q~AGE


  (0, 7) ; V1 
  (1); V1~AGE



  (1);V2~SEX1
  (0, 9) ; V2 


  ; Q2 is not used
  ; Q3 is not used
  ; V3 is not used
; empty $OMEGA




  ; Q2 is not used
  ; Q3 is not used
  ; V3 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


