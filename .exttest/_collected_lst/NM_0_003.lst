$INPUT ID TIME AMT DV
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\Datasets\Vera\darwin/dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
