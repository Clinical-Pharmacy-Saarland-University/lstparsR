$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT DV WT EVID MDV
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\Datasets\Theo/dataset.csv" IGNORE=@
$SUBROUTINE ADVAN2 TRANS2
$PK
  CL = THETA(1) ; CL
  Ka = THETA(2) ; Ka
  V = THETA(3)*(WT/70)**(1)
  SC = V ; V
  ; Q is not used ; Q
  ; V2 is not used ; V2
  ; V3 is not used ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F +EPS(1)
$SIGMA
  ;additive error only
  1	; EPS(1)
$THETA
  (0, 5) ; CL 
  (0, 1) ; Ka 
  (0, 50) ; V 
  ; Q is not used
  ; V2 is not used
  ; V3 is not used
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
; empty $OMEGA



  ; Q is not used
  ; V2 is not used
  ; V3 is not used
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


