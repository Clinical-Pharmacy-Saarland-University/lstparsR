$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE DV DROP MDV AGE SEX LBM DROP CMT EVID
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\RemiR/data.csv" IGNORE=@
$SUBROUTINE ADVAN3 TRANS4
$PK

  CL = THETA(1) *(1 + THETA(2) * (AGE)) *(LBM/50)**(THETA(3))  ; CL


  TVQSEX = 0
  IF(SEX == 1) THEN
  TVQSEX = THETA(4)
  ENDIF
  Q = THETA(5)   *(1 + TVQSEX) ; Q


  TVV1SEX = 0
  IF(SEX == 1) THEN
  TVV1SEX = THETA(6)
  ENDIF
  V1 = THETA(7) *(1 + THETA(8) * (AGE))  *(1 + TVV1SEX)
  SC = V1 ; V1


  TVV2SEX = 0
  IF(SEX == 1) THEN
  TVV2SEX = THETA(9)
  ENDIF
  V2 = THETA(10)   *(1 + TVV2SEX) ; V2
  ; Q2 is not used ; Q2
  ; Q3 is not used ; Q3
  ; V3 is not used ; V3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA

  (0, 2) ; CL 
  (1); CL~AGE
  (1); CL~LBM


  (1);Q~SEX1
  (0, 1) ; Q 




  (1);V1~SEX1
  (0, 7) ; V1 
  (1); V1~AGE



  (1);V2~SEX1
  (0, 9) ; V2 


  ; Q2 is not used
  ; Q3 is not used
  ; V3 is not used
; empty $OMEGA




  ; Q2 is not used
  ; Q3 is not used
  ; V3 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


