$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT RATE DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN12 ;; advan12 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IF(OCC.EQ.1) IOVV = ETA(7) 
  IF(OCC.EQ.2) IOVV = ETA(8) 
  IF(OCC.EQ.3) IOVV = ETA(9)  
  TVV2=THETA(1) *EXP(CWTKGZERO*THETA(8))  *CAGE**THETA(9)   *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IF(OCC.EQ.1) IOVCL = ETA(4) 
  IF(OCC.EQ.2) IOVCL = ETA(5) 
  IF(OCC.EQ.3) IOVCL = ETA(6)
  TVCL= THETA(3) *CWTKGONE**THETA(10) *CAGE**THETA(11) *CCRCL**THETA(12)  *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  K23=THETA(4)
  K32=THETA(5)
  K24=THETA(6)
  K42=THETA(7)  
  D1=THETA(13)  ; infusion only    
  TVKA=THETA(2) 
  KA=TVKA      
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F +EPS(1)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,20)	; THETA(3) CL UNITS =  L/HR
  (0.001,0.1) 	; THETA(4) K23 
  (0.001,0.1)	; THETA(5) K32 
  (0.001,0.1) 	; THETA(6) K24  
  (0.001,0.1) 	; THETA(7) K42  
  ;; init for K23~WT   
  (-1,0.01) 	; THETA(8) EXPONENTIAL volume ~WT    

  (-4,0.8) 	; THETA(9) POWER volume ~AGE  

  (-4,.7) 	; THETA(10) POWER clearance~WT  
  (-4,.7) 	; THETA(11) POWER clearance~AGE  
  (-4,-0.2) 	; THETA(12) POWER clearance~CRCL 

  (0.01,0.2) 		;; THETA(13) D1  
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  

$OMEGA ;;  
  0.1 		;; ETA(3) ETA ON D1   
$OMEGA BLOCK(1) ; ETA(4)
  0.1 
$OMEGA BLOCK SAME ; ETA(5)
$OMEGA BLOCK SAME ; ETA(6)
$OMEGA BLOCK(1) ; ETA(7)
  0.1 
$OMEGA BLOCK SAME ; ETA(8)
$OMEGA BLOCK SAME ; ETA(9)
$SIGMA   
  200 	; EPS(1) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 2, 'K23~WT': 0, 'KAETA': 0, 'V2~WT': 2, 'V2~AGE': 1, 'V2~SEX': 0, 'V2~COV2': 0, 'CL~WT': 1, 'CL~AGE': 1, 'CL~CRCL': 1, 'CL~COV1': 0, 'IOVCL': 0, 'IOVV': 0, 'INITCL': 1, 'ETAD1LAG': 2, 'D1LAG': 1, 'RESERR': 1})
