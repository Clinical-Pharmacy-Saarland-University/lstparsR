$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME DV AMT EVID MDV CMT WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
  CL = THETA(1)  ; CL
  Ka = THETA(2) ; Ka
  ; V is not used ; V
  Q = THETA(3) ; Q
  V2 = THETA(4) *(WT/70)**(THETA(5))
  SC = V2 ; V2
  V3 = THETA(6)  * EXP(ETA(1)) ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))
$SIGMA
  ;proportional error
  0.015	; EPS(1)
$THETA
  (0, 2) ; CL 

  (0, 1) ; Ka
  ; V is not used
  (0, 25) ; Q
  (0, 5) ; V2 
  (0.5); V2~WT
  (0, 1) ; V3
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$OMEGA

  ; Ka is not used
  ; V is not used
  ; Q is not used

  0.1  ; V3
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


