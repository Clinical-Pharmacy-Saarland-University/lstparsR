$PROBLEM    2 compartment fitting
$INPUT       ID TIME AMT RATE DV MDV EVID WT AGE SEX BUN SCR OCC CRCL COV1 COV2

$DATA      D:\Users\raban.heller\Documents\GitHub\pyDarwinXploR\Examples\ExamplePenFunc/dataWithPeriod.csv IGNORE=@

$SUBROUTINE ADVAN4 ;; advan4 
$PK      
  CWTKGONE = WT/81  ;; WEIGHT CENTERED ON ONE
  CWTKGZERO = WT-81 ;; WEIGHT CENTERED ON ZERO
  CAGE = AGE/60     ;; AGE CENTERED ON ONE
  CCRCL = CRCL/85.6 ;; CRCL CENTERD ON ONE
  CCOV1 = COV1-15.4 ;; COVARIATE 1 CENTERED ON ZERO
  IF(OCC.EQ.1) IOVV = ETA(6) 
  IF(OCC.EQ.2) IOVV = ETA(7) 
  IF(OCC.EQ.3) IOVV = ETA(8)  
  TVV2=THETA(1) *CWTKGONE**THETA(6)  *CAGE**THETA(7) *EXP(COV2*THETA(8))  *EXP(IOVV)
  V2=TVV2*EXP(ETA(2))   
  IF(OCC.EQ.1) IOVCL = ETA(3) 
  IF(OCC.EQ.2) IOVCL = ETA(4) 
  IF(OCC.EQ.3) IOVCL = ETA(5)
  TVCL= THETA(3) *CWTKGONE**THETA(9) *CAGE**THETA(10) *CCRCL**THETA(11) *EXP(CCOV1*THETA(12)) *EXP(IOVCL)
  CL=TVCL*EXP(ETA(1)) 

  K=CL/V2      
  K23=THETA(4)
  K32=THETA(5)  
  D1=THETA(13)  ; infusion only    
  TVKA=THETA(2) 
  KA=TVKA      
  S2 = V2 
$ERROR     	
  REP = IREP      
  IPRED =F  
  IOBS = F +EPS(1)
  Y=IOBS
$THETA      
  (0.001,100) 	; THETA(1) V  UNITS = L
  (0.001, 10) 	; THETA(2) KA UNITS = 1/HR    
  (0.001,2)	; THETA(3) CL UNITS =  L/HR
  (0.001,0.02)  	 ; THETA(4) K23 
  (0.001,0.3) 	 ; THETA(5) K32 
  ; init for K23~WT    
  (-4,0.8) 	; THETA(6) POWER volume ~WT    

  (-4,0.8) 	; THETA(7) POWER volume ~AGE  
  (-4,0.1) 	; THETA(8) EXPONENTIAL volume ~COV2 
  (-4,.7) 	; THETA(9) POWER clearance~WT  
  (-4,.7) 	; THETA(10) POWER clearance~AGE  
  (-4,-0.2) 	; THETA(11) POWER clearance~CRCL 
  (-4,0.1) 	; THETA(12) EXPONENTIAL CL~COV1 
  (0.01,0.2) 		;; THETA(13) D1  
$OMEGA    
  0.1  		; ETA(1) CLEARANCE 
  0.4  		; ETA(2) VOLUME  


$OMEGA BLOCK(1) ; ETA(3)
  0.1 
$OMEGA BLOCK SAME ; ETA(4)
$OMEGA BLOCK SAME ; ETA(5)
$OMEGA BLOCK(1) ; ETA(6)
  0.1 
$OMEGA BLOCK SAME ; ETA(7)
$OMEGA BLOCK SAME ; ETA(8)
$SIGMA   
  200 	; EPS(1) additive error

$EST METHOD=COND INTER MAX = 9999 MSFO=MSF1 PRINT = 10
$COV UNCOND PRINT=E  PRECOND=1 PRECONDS=TOS  MATRIX = R

;; Phenotype: ({'ADVAN': 1, 'K23~WT': 0, 'KAETA': 0, 'V2~WT': 1, 'V2~AGE': 1, 'V2~SEX': 0, 'V2~COV2': 1, 'CL~WT': 1, 'CL~AGE': 1, 'CL~CRCL': 1, 'CL~COV1': 1, 'IOVCL': 0, 'IOVV': 0, 'INITCL': 0, 'ETAD1LAG': 0, 'D1LAG': 1, 'RESERR': 1})
