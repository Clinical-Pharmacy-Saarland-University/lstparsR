$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE MDV EVID DV WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN1 TRANS2
$PK
  CL = THETA(1) *(WT)**(THETA(2)) ; CL
  V = THETA(3)  * EXP(ETA(1))
  SC = V ; V
  ALAG1 = THETA(4)   * EXP(ETA(2)) ; ALAG1
  ; F1
  ; Ka is not used ; Ka
  ; ALAG2 is not used ; ALAG2
  ; F2 is not used ; F2
  ; Q is not used ; Q
  ; V1 is not used ; V1
  ; V2 is not used ; V2
  ; V3 is not used ; V3
  ; ALAG3 is not used ; ALAG3
  ; F3 is not used ; F3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA
  (0, 1) ; CL 
  (0.1); CL~WT
  (0, 5) ; V 

  (0, 1) ; ALAG1

  ; F1 is not used
  ; Ka is not used
  ; ALAG2 is not used
  ; F2 is not used
  ; Q is not used
  ; V1 is not used
  ; V2 is not used
  ; V3 is not used
  ; ALAG3 is not used
  ; F3 is not used
$OMEGA

  0.3  ; V
  0.3  ; ALAG1
  ; F1 is not used
  ; Ka is not used
  ; ALAG2 is not used
  ; F2 is not used
  ; Q is not used
  ; V1 is not used
  ; V2 is not used
  ; V3 is not used
  ; ALAG3 is not used
  ; F3 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


