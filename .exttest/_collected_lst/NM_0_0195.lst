$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT DV WT EVID MDV
$DATA "D:\Users\selzer\Repos\GH\pyDarwinXploR\Datasets\Theo/dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
  CL = THETA(1)*(WT/70)**(0.75) ; CL
  Ka = THETA(2) * EXP(ETA(1)) ; Ka
  ; V is not used ; V
  Q = THETA(3) * EXP(ETA(2)) ; Q
  V2 = THETA(4)*(WT/70)**(1)
  SC = V2 ; V2
  V3 = THETA(5) ; V3
  ; Q3 is not used ; Q3
  ; Q4 is not used ; Q4
  ; V4 is not used ; V4
$ERROR
  IPRED = F
  Y = F +EPS(1)
$SIGMA
  ;additive error only
  1	; EPS(1)
$THETA
  (0, 5) ; CL 
  (0, 1) ; Ka 
  ; V is not used
  (0, 6) ; Q 
  (0, 50) ; V2 
  (0, 100) ; V3 
  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$OMEGA

  0.3  ; Ka
  ; V is not used
  0.3  ; Q


  ; Q3 is not used
  ; Q4 is not used
  ; V4 is not used
$EST METHOD = COND INTER NOABORT MAX = 999999
$TABLE ID TIME AMT DV PRED IPRED WRES CWRES FILE=results.tab NOPRINT NOAPPEND ONEHEADER
$COV UNCOND PRINT=E


