$SIZES PD=-1000 LVR=-150 LTH=-200
$PROBLEM single pyDarwin individual, one among multitude
$INPUT ID TIME AMT RATE MDV EVID DV WT DROP
$DATA "../../../dataset.csv" IGNORE=@
$SUBROUTINE ADVAN4 TRANS4
$PK
  CL = THETA(1) *(WT)**(THETA(2)) * EXP(ETA(1)) ; CL
  ; V is not used ; V
  ; ALAG1
  F1 = THETA(3)  *(WT)**(THETA(F1~WT)) ; F1
  Ka = THETA(4) *(WT)**(THETA(5)) * EXP(ETA(2)) ; Ka
  ALAG2 = THETA(6)  ; ALAG2
  F2 = THETA(7)  * EXP(ETA(3)) ; F2
  Q = THETA(8)  * EXP(ETA(4)) ; Q
  ; V1 is not used ; V1
  V2 = THETA(9)  * EXP(ETA(5))
  SC = V2 ; V2
  V3 = THETA(10) *(WT)**(THETA(11)) * EXP(ETA(6)) ; V3
  ALAG3 = THETA(12)  * EXP(ETA(7)) ; ALAG3
  F3 = THETA(13)  * EXP(ETA(8)) ; F3
$ERROR
  IPRED = F
  Y = F *(1+EPS(1))+EPS(2)
$SIGMA
  ;proportional error
  0.2	; EPS(1)
  ;additive error
  1	; EPS(2)
$THETA
  (0, 1) ; CL 
  (0.1); CL~WT
  ; V is not used
  ; ALAG1 is not used
  (0, 0.5) ; F1
  (0, 1) ; Ka 
  (0.1); Ka~WT
  (0, 1) ; ALAG2
  (0, 0.5) ; F2
  (0, 1) ; Q 

  ; V1 is not used
  (0, 5) ; V2 

  (0, 1) ; V3 
  (0.1); V3~WT
  (0, 1) ; ALAG3
  (0, 0.5) ; F3
$OMEGA
  0.3  ; CL
  ; V is not used
  ; ALAG1 is not used
  ; F1 is not used
  0.3  ; Ka
  ; ALAG2 is not used
  0.3  ; F2
  0.3  ; Q
  ; V1 is not used
  0.3  ; V2
  0.3  ; V3
  0.3  ; ALAG3
  0.3  ; F3
$EST METHOD = COND INTER NOABORT MAX = 999999
$COV UNCOND PRINT=E


